{
  "id": "base_rpg_room",
  "name": "Grid RPG AI Room Pack",
  "version": 2,
  "tileSize": 64,
  "style": "usable Pokemon-like 3/4 top-down RPG room grid assets; deterministic transparent PNG tiles and furniture sprites",
  "perspective": {
    "camera": "3/4 top-down handheld RPG interior",
    "grid": "x/y room grid, y increases toward screen bottom",
    "depth": "floor < wall < object < character < overlay; object depth sorts by y"
  },
  "recommendedRenderer": {
    "filter": "nearest",
    "scale": "integer",
    "allowOverflowDecor": true,
    "background": "transparent-alpha"
  },
  "usage": {
    "flow": [
      "ai_home_assets.room_schema",
      "ai_home_assets.search_assets",
      "town_builder.place_furniture"
    ],
    "coordinates": "Room grid is 12x10 or 20x20. Use tileWidth/tileHeight as occupied grid cells. Doors/windows attach to walls, furniture occupies object cells.",
    "grid_rule": "Structure tiles are 1x1 or 1x2; carpets provide center/edge/corner tiles; furniture is placed after room structure and validated for overlap/pathing."
  },
